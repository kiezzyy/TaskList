generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model TaskStatus {
  id        String   @id @default(cuid())
  name      String   @unique
  sortOrder Int
  tasks     Task[]

  @@map("task_statuses")
}

model TaskList {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tasks     Task[]

  @@index([name])
  @@map("task_lists")
}

model Task {
  id          String        @id @default(cuid())
  listId      String
  statusId    String
  name        String
  description String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  list        TaskList      @relation(fields: [listId], references: [id], onDelete: Cascade)
  status      TaskStatus    @relation(fields: [statusId], references: [id])
  sessions    TaskSession[]

  @@index([listId])
  @@index([statusId])
  @@index([name])
  @@map("tasks")
}

model TaskSession {
  id              String    @id @default(cuid())
  taskId          String
  startedAt       DateTime
  endedAt         DateTime?
  durationSeconds Int       @default(0)
  task            Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([startedAt])
  @@map("task_sessions")
}

model WorkspaceMetadata {
  id            String   @id @default(cuid())
  appVersion    String
  schemaVersion Int
  lastExportAt  DateTime?
  updatedAt     DateTime @updatedAt

  @@map("workspace_metadata")
}
